main:
    ADDI X0, XZR, #100
    ADDI X1, XZR, #10
    BL fill_array
    DUMP
    HALT

fill_array:
    ADDI X2, XZR, #0

fill_loop:
    SUBS XZR, X2, X1
    B.GE fill_done

    LSL X3, X2, #3
    ADD X4, X0, X3
    ADD X5, X2, XZR
    STUR X5, [X4, #0]

    ADDI X2, X2, #1
    B fill_loop

fill_done:
    BR LR